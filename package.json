{
  "name": "gestione-prenotazioni-typescript",
  "version": "1.0.0",
  "description": "Sistema di Gestione Prenotazioni Sale Riunioni - WorkSphere Solutions",
  "main": "dist/index.js",
  "scripts": {
    "build:backend": "tsc",
    "build:frontend": "esbuild src/frontend/app.ts --bundle --outfile=public/dist/app.js --target=es2020 --format=esm",
    "build": "npm run build:backend && npm run build:frontend",
    "watch:frontend": "esbuild src/frontend/app.ts --bundle --outfile=public/dist/app.js --watch",
    "start": "node dist/index.js",
    "dev": "concurrently \"npm run watch:frontend\" \"npm run start\""
  },
  "keywords": ["typescript", "booking", "meeting-room"],
  "author": "WorkSphere Solutions",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.19.8",
    "typescript": "^5.3.2"
  }
}
